<script type="module">
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { STLLoader } from 'three/addons/loaders/STLLoader.js';

const frame = document.getElementById('viewer-frame');
const canvas = document.getElementById('viewer-canvas');
const dropZone = document.getElementById('drop-zone');
const browseBtn = document.getElementById('browse-btn');
const fileInput = document.getElementById('file-input');
const loadingState = document.getElementById('loading-state');
const loadingText = document.getElementById('loading-text');
const errorBanner = document.getElementById('error-banner');
const viewerControls = document.getElementById('viewer-controls');
const viewerInfo = document.getElementById('viewer-info');
const infoName = document.getElementById('info-name');
const infoStats = document.getElementById('info-stats');
const btnWireframe = document.getElementById('btn-wireframe');
const btnEdges = document.getElementById('btn-edges');
const btnReset = document.getElementById('btn-reset');
const btnNew = document.getElementById('btn-new');

// This viewer loads the real STEP file (the exact CAD export, curves and
// surfaces — not a pre-baked mesh) and tessellates it live in the browser
// via occt-import-js, a WASM build of the OpenCascade kernel. That's higher
// fidelity than a fixed .stl, at the cost of a real wait on first load
// (STEP parsing is CPU-bound; expect ~20-40s depending on the visitor's
// device). An .stl copy is kept as an automatic silent fallback in case
// STEP parsing fails or the browser can't run the WASM module.
//
// Place both files relative to this page:
//   models/end-effector.stp   (primary — the real STEP geometry)
//   models/end-effector.stl   (fallback — pre-tessellated)
const DEFAULT_MODEL_URL_STEP = 'models/end-effector.stp';
const DEFAULT_MODEL_URL_STL = 'models/end-effector.stl';
const DEFAULT_MODEL_NAME = 'End-Effector Assembly';
const OCCT_WORKER_TIMEOUT_MS = 90000; // safety net in case parsing hangs

// Hide the manual drop zone until we know whether the fixed model loaded.
dropZone.style.display = 'none';

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(45, 1, 0.01, 10000);
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;
controls.dampingFactor = 0.08;
controls.minDistance = 0.01;
controls.maxDistance = 100000;

scene.add(new THREE.HemisphereLight(0x9fb0d8, 0x0a0e17, 0.9));
const key = new THREE.DirectionalLight(0xffffff, 1.3);
key.position.set(4, 6, 5);
scene.add(key);
const fill = new THREE.DirectionalLight(0xB08D57, 0.5);
fill.position.set(-5, -2, -4);
scene.add(fill);

let modelGroup = null;   // THREE.Group holding one Mesh per solid/shell
let edgesGroup = null;   // THREE.Group holding matching LineSegments
let wireframeOn = false;
let edgesOn = false;
let gridHelper = null;
let occtWorker = null;   // lazily created Web Worker running occt-import-js

function resizeRenderer() {
  const w = frame.clientWidth, h = frame.clientHeight;
  renderer.setSize(w, h, false);
  camera.aspect = w / h;
  camera.updateProjectionMatrix();
}
window.addEventListener('resize', resizeRenderer);
resizeRenderer();

function animate() {
  requestAnimationFrame(animate);
  controls.update();
  renderer.render(scene, camera);
}
animate();

function setLoading(active, text) {
  loadingState.classList.toggle('active', active);
  if (text) loadingText.textContent = text;
}
function showError(msg) {
  errorBanner.textContent = msg;
  errorBanner.classList.add('active');
  setTimeout(() => errorBanner.classList.remove('active'), 6000);
}

['dragenter', 'dragover'].forEach(evt => {
  dropZone.addEventListener(evt, e => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });
});
['dragleave', 'drop'].forEach(evt => {
  dropZone.addEventListener(evt, e => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
  });
});
dropZone.addEventListener('drop', e => {
  const f = e.dataTransfer.files && e.dataTransfer.files[0];
  if (f) loadFile(f);
});
browseBtn.addEventListener('click', () => fileInput.click());
fileInput.addEventListener('change', () => {
  const f = fileInput.files && fileInput.files[0];
  if (f) loadFile(f);
});
btnNew.addEventListener('click', () => {
  loadDefaultModel();
});

const stlLoader = new STLLoader();

function clearModel() {
  if (modelGroup) { scene.remove(modelGroup); modelGroup = null; }
  if (edgesGroup) { scene.remove(edgesGroup); edgesGroup = null; }
  if (gridHelper) { scene.remove(gridHelper); gridHelper = null; }
}

// ─── Web Worker wrapper around occt-import-js ───────────────────────────
// Runs the WASM CAD kernel off the main thread so the page (and the
// elapsed-time readout) stays responsive during the 20-40+ second parse.
function getOcctWorker() {
  if (occtWorker) return occtWorker;
  const workerSrc = `
    self.onmessage = async function (ev) {
      try {
        importScripts('${OCCT_CDN_BASE}occt-import-js.js');
        const occt = await occtimportjs({
          locateFile: (path) => '${OCCT_CDN_BASE}' + path
        });
        const result = occt.ReadStepFile(new Uint8Array(ev.data.buffer), {
          linearUnit: 'millimeter',
          linearDeflectionType: 'absolute_value',
          linearDeflection: 0.25,
          angularDeflection: 0.4
        });
        if (!result.success || !result.meshes || result.meshes.length === 0) {
          throw new Error('STEP parse returned no geometry');
        }
        const transferables = [];
        const meshes = result.meshes.map(m => {
          const position = m.attributes.position.array;
          const normal = m.attributes.normal ? m.attributes.normal.array : null;
          const index = m.index ? m.index.array : null;
          transferables.push(position.buffer);
          if (normal) transferables.push(normal.buffer);
          if (index) transferables.push(index.buffer);
          return { position, normal, index };
        });
        self.postMessage({ ok: true, meshes }, transferables);
      } catch (err) {
        self.postMessage({ ok: false, error: (err && err.message) || String(err) });
      }
    };
  `;
  const blob = new Blob([workerSrc], { type: 'application/javascript' });
  occtWorker = new Worker(URL.createObjectURL(blob));
  return occtWorker;
}

function parseStepInWorker(buffer) {
  return new Promise((resolve, reject) => {
    const worker = getOcctWorker();
    const timeout = setTimeout(() => {
      worker.onmessage = null;
      reject(new Error('STEP parsing timed out'));
    }, OCCT_WORKER_TIMEOUT_MS);

    worker.onmessage = (ev) => {
      clearTimeout(timeout);
      if (ev.data && ev.data.ok) {
        resolve(ev.data.meshes);
      } else {
        reject(new Error((ev.data && ev.data.error) || 'Unknown STEP parsing error'));
      }
    };
    worker.onerror = (err) => {
      clearTimeout(timeout);
      reject(err);
    };
    // Transfer the buffer into the worker rather than copying it.
    worker.postMessage({ buffer }, [buffer]);
  });
}

// Staged loading copy so a 20-40s wait doesn't read as a frozen page.
const STEP_LOADING_STAGES = [
  [0, 'Loading CAD kernel (WASM)…'],
  [2, 'Parsing STEP geometry…'],
  [8, 'Parsing STEP geometry — this can take 20-40s…'],
  [20, 'Still working — complex assemblies take longer…'],
  [40, 'Almost there — building the mesh…'],
];
function startStepLoadingTimer() {
  const startedAt = performance.now();
  setLoading(true, STEP_LOADING_STAGES[0][1]);
  const id = setInterval(() => {
    const elapsed = (performance.now() - startedAt) / 1000;
    let msg = STEP_LOADING_STAGES[0][1];
    for (const [t, text] of STEP_LOADING_STAGES) {
      if (elapsed >= t) msg = text;
    }
    loadingText.textContent = `${msg} (${elapsed.toFixed(0)}s)`;
  }, 500);
  return () => clearInterval(id);
}

async function loadFile(file) {
  const name = file.name.toLowerCase();
  errorBanner.classList.remove('active');

  if (name.endsWith('.stp') || name.endsWith('.step')) {
    const stopTimer = startStepLoadingTimer();
    try {
      const buffer = await file.arrayBuffer();
      const meshes = await parseStepInWorker(buffer);
      buildSceneFromMeshes(meshes);
      dropZone.style.display = 'none';
      viewerControls.classList.add('active');
      viewerInfo.classList.add('active');
      infoName.textContent = `${file.name} (client-side STEP)`;
      infoStats.textContent = `${countTriangles(meshes).toLocaleString()} triangles`;
    } catch (err) {
      console.error(err);
      showError('Could not parse this STEP file in the browser. Try an .stl instead.');
    } finally {
      stopTimer();
      setLoading(false);
    }
    return;
  }

  if (name.endsWith('.stl')) {
    setLoading(true, 'Parsing STL file…');
    try {
      const buffer = await file.arrayBuffer();
      let geometry;
      try {
        geometry = stlLoader.parse(buffer);
      } catch (parseErr) {
        console.error(parseErr);
        showError('Could not read this STL file. It may be corrupted or use an unsupported variant.');
        return;
      }
      if (!geometry || !geometry.attributes || !geometry.attributes.position || geometry.attributes.position.count === 0) {
        showError('Could not read this STL file. It may be corrupted or empty.');
        return;
      }
      buildSceneFromGeometries([geometry]);
      dropZone.style.display = 'none';
      viewerControls.classList.add('active');
      viewerInfo.classList.add('active');
      infoName.textContent = file.name;
      const triCount = geometry.index ? geometry.index.count / 3 : geometry.attributes.position.count / 3;
      infoStats.textContent = `${Math.round(triCount).toLocaleString()} triangles`;
    } catch (err) {
      console.error(err);
      showError('Something went wrong while reading this file.');
    } finally {
      setLoading(false);
    }
    return;
  }

  showError('Please choose a .stp, .step, or .stl file.');
}

function countTriangles(meshes) {
  let total = 0;
  for (const m of meshes) {
    total += m.index ? m.index.length / 3 : m.position.length / 9;
  }
  return Math.round(total);
}

async function loadDefaultModel() {
  errorBanner.classList.remove('active');
  dropZone.style.display = 'none';

  // 1) Primary path: fetch the real .stp and tessellate it in the browser.
  const stopTimer = startStepLoadingTimer();
  try {
    const res = await fetch(DEFAULT_MODEL_URL_STEP);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const buffer = await res.arrayBuffer();
    const meshes = await parseStepInWorker(buffer);
    buildSceneFromMeshes(meshes);
    viewerControls.classList.add('active');
    viewerInfo.classList.add('active');
    infoName.textContent = `${DEFAULT_MODEL_NAME} (STEP)`;
    infoStats.textContent = `${countTriangles(meshes).toLocaleString()} triangles`;
    stopTimer();
    setLoading(false);
    return;
  } catch (err) {
    console.warn('STEP auto-load failed, falling back to STL:', err);
    stopTimer();
  }

  // 2) Fallback path: pre-tessellated STL, in case STEP parsing failed or
  //    the visitor's browser can't run the WASM module.
  setLoading(true, 'Falling back to pre-tessellated model…');
  try {
    const res = await fetch(DEFAULT_MODEL_URL_STL);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const buffer = await res.arrayBuffer();
    const geometry = stlLoader.parse(buffer);
    if (!geometry || !geometry.attributes || !geometry.attributes.position || geometry.attributes.position.count === 0) {
      throw new Error('Empty geometry');
    }
    buildSceneFromGeometries([geometry]);
    viewerControls.classList.add('active');
    viewerInfo.classList.add('active');
    infoName.textContent = `${DEFAULT_MODEL_NAME} (STL fallback)`;
    const triCount = geometry.index ? geometry.index.count / 3 : geometry.attributes.position.count / 3;
    infoStats.textContent = `${Math.round(triCount).toLocaleString()} triangles`;
  } catch (err) {
    console.warn('Could not auto-load the project model:', err);
    viewerControls.classList.remove('active');
    viewerInfo.classList.remove('active');
    dropZone.style.display = 'flex';
    showError("Couldn't load the model automatically. You can browse for it manually below.");
  } finally {
    setLoading(false);
  }
}

loadDefaultModel();

// Build the scene from raw occt-import-js mesh data (positions/normals/index
// per solid). Kept separate from buildSceneFromGeometries so STEP's
// multi-solid output doesn't need to be merged into one buffer.
function buildSceneFromMeshes(meshes) {
  const geometries = meshes.map(m => {
    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute('position', new THREE.BufferAttribute(m.position, 3));
    if (m.normal) {
      geometry.setAttribute('normal', new THREE.BufferAttribute(m.normal, 3));
    }
    if (m.index) {
      geometry.setIndex(new THREE.BufferAttribute(m.index, 1));
    }
    if (!m.normal) geometry.computeVertexNormals();
    return geometry;
  });
  buildSceneFromGeometries(geometries);
}

function buildSceneFromGeometries(geometries) {
  clearModel();
  wireframeOn = false;
  edgesOn = false;
  btnWireframe.classList.remove('on');
  btnEdges.classList.remove('on');

  // Overall bounding box across every solid, to find the common center.
  const overallBox = new THREE.Box3();
  for (const geometry of geometries) {
    geometry.computeBoundingBox();
    overallBox.union(geometry.boundingBox);
  }
  const center = overallBox.getCenter(new THREE.Vector3());
  const size = overallBox.getSize(new THREE.Vector3());

  const material = new THREE.MeshStandardMaterial({
    color: 0xB08D57, metalness: 0.35, roughness: 0.5, flatShading: false
  });
  const lineMaterial = new THREE.LineBasicMaterial({ color: 0x0a0e17, transparent: true, opacity: 0.5 });

  const meshGroup = new THREE.Group();
  const lineGroup = new THREE.Group();

  for (const geometry of geometries) {
    const mesh = new THREE.Mesh(geometry, material);
    mesh.position.sub(center);
    meshGroup.add(mesh);

    const edgesGeo = new THREE.EdgesGeometry(geometry, 20);
    const lines = new THREE.LineSegments(edgesGeo, lineMaterial);
    lines.position.copy(mesh.position);
    lineGroup.add(lines);
  }
  lineGroup.visible = false;

  scene.add(meshGroup);
  scene.add(lineGroup);
  modelGroup = meshGroup;
  edgesGroup = lineGroup;

  const maxDim = Math.max(size.x, size.y, size.z) || 1;
  gridHelper = new THREE.GridHelper(maxDim * 3, 20, 0xB08D57, 0x2a3550);
  gridHelper.material.transparent = true;
  gridHelper.material.opacity = 0.18;
  gridHelper.position.y = -size.y / 2;
  scene.add(gridHelper);

  frameCamera(maxDim);
}

function frameCamera(maxDim) {
  const dist = maxDim * 2.0 || 5;
  camera.near = Math.max(dist / 1000, 0.001);
  camera.far = dist * 100;
  camera.position.set(dist * 0.7, dist * 0.55, dist * 0.85);
  camera.updateProjectionMatrix();
  controls.target.set(0, 0, 0);
  controls.update();
}

btnWireframe.addEventListener('click', () => {
  wireframeOn = !wireframeOn;
  btnWireframe.classList.toggle('on', wireframeOn);
  if (modelGroup) {
    modelGroup.children.forEach(mesh => { mesh.material.wireframe = wireframeOn; });
  }
});

btnEdges.addEventListener('click', () => {
  edgesOn = !edgesOn;
  btnEdges.classList.toggle('on', edgesOn);
  if (edgesGroup) {
    edgesGroup.visible = edgesOn;
  }
});

btnReset.addEventListener('click', () => {
  if (!modelGroup) return;
  const box = new THREE.Box3().setFromObject(modelGroup);
  const size = box.getSize(new THREE.Vector3());
  const maxDim = Math.max(size.x, size.y, size.z) || 1;
  frameCamera(maxDim);
});
</script>

<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));
</script>
</body>
</html>
