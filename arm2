<!--
  occt-import-js: a WASM build of the OpenCascade CAD kernel, used to parse
  the .stp file directly in the browser (real B-rep -> mesh tessellation,
  same math your CAD software runs on export). It's loaded lazily inside a
  Web Worker (see the module script below) so the page stays responsive
  while it works — STEP parsing is CPU-heavy and can take 20-40+ seconds.
-->
<script>
  const OCCT_CDN_BASE = 'https://cdn.jsdelivr.net/npm/occt-import-js@0.0.23/dist/';
</script>
<style>
  :root {
    --gold: #B08D57;
    --gold-light: #c8a468;
    --navy: #080F2A;
    --bg: #f7f0e0;
    --surface: #fffdf8;
    --surface2: #f0ece1;
    --text: #080F2A;
    --muted: rgba(28,26,24,.55);
    --muted2: rgba(28,26,24,.4);
    --border: rgba(15,42,74,.14);
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'Crimson Pro',Georgia,serif;
    font-size:18px;
    line-height:1.6;
    overflow-x:hidden;
  }
  ::selection{background:rgba(15,42,74,.2);color:#fff}

  /* ═══ NAV ═══ */
  nav{
    position:fixed;top:0;left:0;right:0;z-index:100;
    display:flex;align-items:center;justify-content:space-between;
    padding:1.55rem 3rem;
    background:rgba(247,240,224,.85);
    backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
    border-bottom:1px solid rgba(15,42,74,.08);
  }
  .nav-logo{
    display:flex;align-items:center;gap:.55rem;
    font-family:'JetBrains Mono',monospace;
    font-size:.92rem;font-weight:600;color:var(--navy);
    text-decoration:none;letter-spacing:-.01em;transition:opacity .2s;
  }
  .nav-logo:hover{opacity:.65}
  .nav-mark{
    width:26px;height:26px;border-radius:7px;background:var(--navy);
    display:flex;align-items:center;justify-content:center;
    color:#faf8f0;font-family:'Playfair Display',Georgia,serif;font-weight:700;font-style:italic;font-size:1rem;
    flex-shrink:0;
  }
  .nav-back{
    font-family:'Crimson Pro',Georgia,serif;font-size:.95rem;font-weight:400;
    color:var(--muted);text-decoration:none;
    padding:.4rem .9rem;border-radius:9999px;transition:all .2s;
  }
  .nav-back:hover{color:var(--navy);background:rgba(15,42,74,.06)}

  /* ═══ HERO ═══ */
  .project-hero{
    min-height:55vh;
    padding:10rem 3rem 5rem;
    display:flex;flex-direction:column;justify-content:flex-end;
    position:relative;overflow:hidden;
    border-bottom:1px solid var(--border);
  }
  .project-hero::after{
    content:'01';
    position:absolute;right:-0.02em;top:50%;transform:translateY(-50%);
    font-family:'Playfair Display',Georgia,serif;font-weight:700;font-style:italic;
    font-size:26vw;color:transparent;
    -webkit-text-stroke:1px rgba(176,141,87,.14);
    pointer-events:none;line-height:1;
  }
  .project-eyebrow{
    font-family:'JetBrains Mono',monospace;
    font-size:.72rem;font-weight:600;color:var(--navy);
    text-transform:uppercase;letter-spacing:.22em;
    margin-bottom:1.2rem;display:flex;align-items:center;gap:.6rem;
  }
  .project-eyebrow::before{content:'';width:28px;height:1px;background:var(--navy);opacity:.5}
  .project-hero h1{
    font-family:'Playfair Display',Georgia,serif;font-weight:700;font-style:italic;
    font-size:clamp(3rem,7vw,5.6rem);
    line-height:1.02;color:var(--navy);margin-bottom:2.5rem;
  }
  .project-hero h1 span{color:var(--gold)}
  .project-meta{display:flex;gap:3rem;flex-wrap:wrap}
  .meta-item label{
    font-family:'JetBrains Mono',monospace;font-size:.62rem;color:var(--gold);
    letter-spacing:.2em;text-transform:uppercase;display:block;margin-bottom:.35rem;font-weight:600;
  }
  .meta-item p{font-size:.92rem;color:var(--muted);font-weight:300}

  /* ═══ CONTENT SECTIONS ═══ */
  .content-section{padding:6rem 3rem;border-bottom:1px solid var(--border)}
  .content-section:last-of-type{border-bottom:none}

  .section-header{display:flex;align-items:baseline;gap:1.5rem;margin-bottom:3.5rem}
  .section-num{
    font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--gold);
    letter-spacing:.12em;font-weight:600;
  }
  .section-title{
    font-family:'Playfair Display',Georgia,serif;font-weight:700;font-style:italic;
    font-size:clamp(1.8rem,3.6vw,2.6rem);line-height:1;color:var(--navy);
  }
  .section-line{flex:1;height:1px;background:var(--border)}

  /* ═══ GRIDS ═══ */
  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start}
  .two-col-wide{display:grid;grid-template-columns:3fr 2fr;gap:5rem;align-items:start}

  /* ═══ PROSE ═══ */
  .prose p{color:rgba(28,26,24,.7);font-size:1.05rem;font-weight:300;line-height:1.85;margin-bottom:1.4rem}
  .prose p:last-child{margin-bottom:0}
  .prose strong{color:var(--navy);font-weight:600}

  .prose h3{
    font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.15em;
    text-transform:uppercase;color:var(--gold);margin:2.5rem 0 1rem;font-weight:600;
  }
  .prose ul{list-style:none;display:flex;flex-direction:column;gap:.6rem;margin-bottom:1.5rem}
  .prose li{font-size:1rem;color:rgba(28,26,24,.7);font-weight:300;padding-left:1.5rem;position:relative;line-height:1.65}
  .prose li::before{content:'▸';position:absolute;left:0;color:var(--gold);font-size:.65rem;top:.35rem}

  blockquote{
    border-left:2px solid var(--gold);
    padding:1rem 1.5rem;margin:2rem 0;
    background:rgba(176,141,87,.06);
    border-radius:0 12px 12px 0;
  }
  blockquote p{font-style:italic;color:rgba(28,26,24,.75) !important;font-size:1.05rem !important;margin:0 !important}

  /* ═══ FIGURES ═══ */
  .fig-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);margin:2rem 0;border-radius:16px;overflow:hidden;border:1px solid var(--border)}
  .fig-grid.single{grid-template-columns:1fr}
  .fig-grid.three{grid-template-columns:1fr 1fr 1fr}

  figure{background:var(--surface);overflow:hidden;margin:0}
  figure img{
    width:100%;height:280px;object-fit:cover;display:block;
    filter:sepia(8%) saturate(85%);transition:filter .35s,transform .4s;
  }
  figure img.tall{height:360px}
  figure:hover img{filter:sepia(0%) saturate(100%);transform:scale(1.02)}
  figcaption{
    padding:.75rem 1rem;font-family:'JetBrains Mono',monospace;font-size:.64rem;
    color:var(--muted);letter-spacing:.05em;border-top:1px solid var(--border);
  }

  /* ═══ CHIPS ═══ */
  .chip-row{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1rem}
  .chip{
    font-family:'JetBrains Mono',monospace;font-size:.64rem;letter-spacing:.08em;
    text-transform:uppercase;color:var(--muted);border:1px solid var(--border);
    padding:.35rem .85rem;border-radius:9999px;background:var(--surface);
  }

  /* ═══ CALLOUT ═══ */
  .callout{
    background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--gold);
    padding:1.5rem 2rem;margin:2rem 0;border-radius:0 16px 16px 0;
    box-shadow:0 12px 28px -18px rgba(15,42,74,.18);
  }
  .callout-label{
    font-family:'JetBrains Mono',monospace;font-size:.64rem;letter-spacing:.15em;
    text-transform:uppercase;color:var(--gold);margin-bottom:.75rem;font-weight:600;
  }
  .callout p{font-size:1rem;color:rgba(28,26,24,.7);font-weight:300;line-height:1.7;margin:0}

  /* ═══ PROJECT NAV ═══ */
  .project-nav{border-top:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr}
  .project-nav a{
    padding:2.5rem 3rem;text-decoration:none;color:var(--text);
    transition:background .3s;border-right:1px solid var(--border);
  }
  .project-nav a:last-child{border-right:none;text-align:right}
  .project-nav a:hover{background:rgba(176,141,87,.08)}
  .pnav-label{
    font-family:'JetBrains Mono',monospace;font-size:.62rem;color:var(--gold);
    letter-spacing:.2em;text-transform:uppercase;display:block;margin-bottom:.5rem;font-weight:600;
  }
  .pnav-title{font-family:'Playfair Display',Georgia,serif;font-weight:700;font-style:italic;font-size:1.5rem;color:var(--navy)}

  /* ═══ TIMELINE BAR ═══ */
  .timeline-bar{display:flex;align-items:center;gap:1rem;margin-bottom:2.5rem}
  .timeline-bar .tbar-label{
    font-family:'JetBrains Mono',monospace;font-size:.68rem;color:var(--muted);letter-spacing:.05em;white-space:nowrap;
  }
  .timeline-bar .tbar-line{flex:1;height:1px;background:var(--border);position:relative}
  .timeline-bar .tbar-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0}

  /* ═══ FOOTER ═══ */
  footer{
    border-top:1px solid var(--border);
    padding:2rem 3rem;
    display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.75rem;
  }
  footer span{
    font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--muted2);letter-spacing:.06em;
  }

  /* ═══ 3D MODEL VIEWER ═══ */
  .viewer-frame{
    position:relative;
    border-radius:20px;overflow:hidden;
    border:1px solid var(--border);
    background:radial-gradient(circle at 30% 20%,#182238,#0a0e17 75%);
    height:min(60vh,560px);min-height:380px;
    box-shadow:0 24px 48px -24px rgba(15,42,74,.25);
  }
  #viewer-canvas{position:absolute;inset:0;width:100%;height:100%;display:block;cursor:grab}
  #viewer-canvas:active{cursor:grabbing}

  .drop-zone{
    position:absolute;inset:0;z-index:5;
    display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;
    gap:1.2rem;padding:2rem;color:#f2ede1;transition:background .2s;
  }
  .drop-zone.drag-over{background:rgba(176,141,87,.12)}
  .drop-icon{
    width:60px;height:60px;border-radius:50%;
    border:1.5px dashed rgba(176,141,87,.55);
    display:flex;align-items:center;justify-content:center;
    font-size:1.5rem;color:var(--gold);
  }
  .drop-zone h2{
    font-family:'Playfair Display',Georgia,serif;font-weight:700;font-style:italic;font-size:1.35rem;color:#f2ede1;
  }
  .drop-zone p{font-size:.88rem;color:rgba(242,237,225,.55);max-width:360px;line-height:1.6;font-weight:300}
  .browse-btn{
    font-family:'JetBrains Mono',monospace;font-weight:500;font-size:.8rem;
    color:#0a0e17;background:var(--gold);
    padding:.75rem 1.5rem;border-radius:9999px;border:none;cursor:pointer;transition:all .25s;
  }
  .browse-btn:hover{background:var(--gold-light);transform:translateY(-1px)}
  .file-types{
    font-family:'JetBrains Mono',monospace;font-size:.64rem;color:rgba(242,237,225,.4);
    letter-spacing:.08em;text-transform:uppercase;
  }

  .loading-state{
    position:absolute;inset:0;z-index:6;
    display:none;flex-direction:column;align-items:center;justify-content:center;gap:1rem;
    background:rgba(10,14,23,.88);color:#f2ede1;
  }
  .loading-state.active{display:flex}
  .spinner{
    width:36px;height:36px;border-radius:50%;
    border:2.5px solid rgba(176,141,87,.25);border-top-color:var(--gold);
    animation:spin .9s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg)}}
  .loading-state span{font-family:'JetBrains Mono',monospace;font-size:.76rem;letter-spacing:.04em;color:rgba(242,237,225,.7)}

  .error-banner{
    position:absolute;left:1.1rem;right:1.1rem;bottom:1.1rem;z-index:7;display:none;
    background:rgba(178,50,40,.14);border:1px solid rgba(178,50,40,.4);
    color:#ffd9d4;border-radius:12px;padding:.85rem 1.1rem;
    font-family:'JetBrains Mono',monospace;font-size:.76rem;line-height:1.6;
  }
  .error-banner.active{display:block}

  .viewer-controls{
    position:absolute;top:1rem;right:1rem;z-index:8;display:flex;gap:.5rem;
    opacity:0;pointer-events:none;transition:opacity .25s;
  }
  .viewer-controls.active{opacity:1;pointer-events:auto}
  .vc-btn{
    width:34px;height:34px;border-radius:9999px;
    background:rgba(10,14,23,.55);border:1px solid rgba(176,141,87,.3);
    color:#f2ede1;font-family:'JetBrains Mono',monospace;font-size:.85rem;
    display:flex;align-items:center;justify-content:center;cursor:pointer;
    transition:all .2s;backdrop-filter:blur(6px);
  }
  .vc-btn:hover{background:rgba(176,141,87,.25);border-color:var(--gold)}
  .vc-btn.on{background:var(--gold);color:#0a0e17;border-color:var(--gold)}

  .viewer-info{
    position:absolute;bottom:1rem;left:1rem;z-index:8;
    display:none;flex-direction:column;gap:.15rem;
    font-family:'JetBrains Mono',monospace;font-size:.68rem;
    color:rgba(242,237,225,.55);letter-spacing:.02em;
    background:rgba(10,14,23,.4);backdrop-filter:blur(6px);
    border-radius:10px;padding:.55rem .85rem;
  }
  .viewer-info.active{display:flex}
  .viewer-info strong{color:#f2ede1;font-weight:600}

  .viewer-note{
    margin-top:1rem;font-size:.8rem;color:var(--muted2);
    font-family:'JetBrains Mono',monospace;letter-spacing:.01em;
    display:flex;align-items:center;gap:.5rem;
  }
  .viewer-note::before{content:'●';color:var(--gold);font-size:.6rem}

  /* ═══ ANIMATED GEARS ═══ */
  .gear-cluster{
    position:absolute;top:6.5rem;right:3rem;
    width:170px;height:170px;
    pointer-events:none;z-index:0;
  }
  .gear-cluster svg{position:absolute;display:block}
  .gear-cluster .gear-a{
    width:112px;height:112px;top:0;left:34px;
    opacity:.16;
    animation:spin-cw 22s linear infinite;
  }
  .gear-cluster .gear-b{
    width:70px;height:70px;top:78px;left:0;
    opacity:.16;
    animation:spin-ccw 15s linear infinite;
  }
  @keyframes spin-cw{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
  @keyframes spin-ccw{from{transform:rotate(0deg)}to{transform:rotate(-360deg)}}
  @media(max-width:900px){
    .gear-cluster{display:none}
  }

  @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
  .reveal{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}
  .reveal.visible{opacity:1;transform:none}

  @media(max-width:900px){
    nav{padding:1.15rem 1.4rem}
    .project-hero{padding:8rem 1.4rem 3rem}
    .content-section{padding:4rem 1.4rem}
    .two-col,.two-col-wide{grid-template-columns:1fr;gap:2.5rem}
    .fig-grid{grid-template-columns:1fr}
    .fig-grid.three{grid-template-columns:1fr}
    .project-nav{grid-template-columns:1fr}
    .project-nav a{border-right:none;border-bottom:1px solid var(--border)}
    .project-nav a:last-child{text-align:left}
    footer{padding:1.75rem 1.4rem}
  }
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="index.html"><span class="nav-mark">T</span>Tanmay Poddar</a>
  <a class="nav-back" href="index.html">← Back to Portfolio</a>
</nav>

<!-- HERO -->
