<!-- 3D MODEL VIEWER -->
<div class="content-section">
  <div class="section-header reveal">
    <span class="section-num">3D</span>
    <h2 class="section-title">Interactive Model</h2>
    <div class="section-line"></div>
  </div>
  <div class="reveal">
    <p style="color:rgba(28,26,24,.7);font-size:1.02rem;font-weight:300;line-height:1.8;max-width:640px;margin-bottom:1.8rem;">The final end-effector assembly, loaded below from the original STEP file — rotate, zoom, and toggle wireframe or edge views, right in your browser. First load parses the real CAD geometry client-side, so it can take 20-40 seconds.</p>
    <div class="viewer-frame" id="viewer-frame">
      <canvas id="viewer-canvas"></canvas>

      <div class="drop-zone" id="drop-zone">
        <div class="drop-icon">⬇</div>
        <h2>Model unavailable</h2>
        <p>The end-effector model couldn't be loaded automatically. You can browse for the .stp or .stl file manually below.</p>
        <button class="browse-btn" id="browse-btn" type="button">Browse File</button>
        <input type="file" id="file-input" accept=".stp,.step,.STP,.STEP,.stl,.STL" hidden>
        <div class="file-types">.STEP · .STL</div>
      </div>

      <div class="loading-state" id="loading-state">
        <div class="spinner"></div>
        <span id="loading-text">Loading model…</span>
      </div>

      <div class="error-banner" id="error-banner"></div>

      <div class="viewer-controls" id="viewer-controls">
        <button class="vc-btn" id="btn-wireframe" title="Toggle wireframe">◧</button>
        <button class="vc-btn" id="btn-edges" title="Toggle edges">▦</button>
        <button class="vc-btn" id="btn-reset" title="Reset view">⟲</button>
        <button class="vc-btn" id="btn-new" title="Reload model">↺</button>
      </div>

      <div class="viewer-info" id="viewer-info">
        <span><strong id="info-name"></strong></span>
        <span id="info-stats"></span>
      </div>
    </div>
    <div class="viewer-note">Drag to orbit · Scroll to zoom · Right-click drag to pan</div>
  </div>
</div>

<!-- OVERVIEW -->
<div class="content-section">
  <div class="section-header reveal">
    <span class="section-num">01</span>
    <h2 class="section-title">Project Overview</h2>
    <div class="section-line"></div>
  </div>
